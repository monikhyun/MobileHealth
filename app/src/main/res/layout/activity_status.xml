<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 상단 날짜 및 아이콘 영역 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFF0F8FF"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_date"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="2025년 5월 6일 ▼"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <ImageView
            android:id="@+id/btn_profile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_alarm"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_alarm"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_setting"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_setting"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/barChartSection"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        android:elevation="6dp"
        android:background="@drawable/rounded_container"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inBodySection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Spinner
            android:id="@+id/barChartFilterSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:entries="@array/bar_chart_filter_items"
            android:padding="4dp" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_container"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/inBodySection"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:orientation="vertical"
        android:elevation="6dp"
        android:background="@drawable/rounded_container"
        android:layout_marginTop="40dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/barChartSection"
        app:layout_constraintBottom_toTopOf="@id/avgLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.25">

        <!-- InBody Header Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/inBodyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In-Body"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Spinner
                android:id="@+id/inBodyOptionSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:entries="@array/inBody_items"
                app:layout_constraintStart_toEndOf="@id/inBodyLabel"
                app:layout_constraintTop_toTopOf="@id/inBodyLabel" />

            <TextView
                android:id="@+id/lastRecordDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="2025.05.06"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/inBodyLabel" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/inBodyChartSection"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rounded_container"
            app:layout_constraintTop_toBottomOf="@id/inBodySection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 전체 보기용 BarChart -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/inBodyBarChart"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:visibility="visible" />

            <!-- 항목별 보기용 LineChart -->
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/inBodyLineChart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>
    </LinearLayout>

    <!-- 평균 활동량 -->
    <LinearLayout
        android:id="@+id/avgLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:elevation="6dp"
        android:background="@drawable/rounded_container"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inBodySection">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="소모 칼로리 "
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/일"
            android:textColor="#FF0000"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  활동 시간 "
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF0000"
            android:textSize="14sp" />
    </LinearLayout>
    <!-- 하단 네비게이션 바: 기존 navigationBar 재활용 -->
    <LinearLayout
        android:id="@+id/navigationBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F9F9F9"
        android:paddingVertical="8dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 홈 -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 운동 -->
        <LinearLayout
            android:id="@+id/nav_workout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_workout"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_exercise_selected"
                app:tint="#FF7C8C" />

            <TextView
                android:id="@+id/text_workout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="운동"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 식단 -->
        <LinearLayout
            android:id="@+id/nav_meal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_meal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_diet"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_meal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="식단"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 친구 -->
        <LinearLayout
            android:id="@+id/nav_friends"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_friends"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_friends"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="친구"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 통계 -->
        <LinearLayout
            android:id="@+id/nav_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_stats"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_stats"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="통계"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
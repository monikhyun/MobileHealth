<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="80dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/exercise_item_bg"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginStart="12dp"
    android:gravity="center_vertical">

    <!-- 프로필 이미지 -->
    <ImageView
        android:id="@+id/image_profile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_cat_profile"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:background="@drawable/profile_circle_background"
        android:contentDescription="프로필 이미지" />

    <!-- 이름 -->
    <TextView
        android:id="@+id/text_friend_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="문익현"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- 계급 아이콘 -->
    <ImageView
        android:id="@+id/image_rank"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_rank_leaf"
        android:contentDescription="계급" />

    <Space
        android:layout_width="40dp"
        android:layout_height="0dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/confirm_button"
        android:layout_width="60dp"
        android:layout_height="32dp"
        android:backgroundTint="#0BFF34"
        android:text="확인"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="#000000"
        app:cornerRadius="16dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:gravity="center"
        android:padding="0dp" />
</LinearLayout>
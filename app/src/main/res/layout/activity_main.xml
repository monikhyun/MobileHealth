<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/white"
    android:paddingTop="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Auth.MainActivity">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:background="#FEF7FF"
        android:paddingVertical="8dp"
        android:paddingLeft="26dp"
        android:paddingRight="4dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="28dp"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints">
        <Spinner
            android:id="@+id/topDropdownSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:layout_marginEnd="11dp"
            android:backgroundTint="@android:color/black"
            android:dropDownHorizontalOffset="0dp"
            android:dropDownVerticalOffset="4dp"
            android:gravity="center"
            android:spinnerMode="dropdown" />


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">
        </LinearLayout>
        <ImageView
            android:id="@+id/btn_profile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_alarm"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_alarm"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_setting"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_setting"/>
    </LinearLayout>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/navigationBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_container"
                android:elevation="2dp"
                android:layout_marginHorizontal="8dp">
                <!-- Calendar -->
                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>


            <!-- 오늘 운동 & 걸음 수 -->
            <LinearLayout
                android:layout_marginTop="12dp"
                android:paddingVertical="12dp"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_container"
                android:orientation="horizontal">

                <!-- 오늘 운동 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_container"
                    android:elevation="4dp"
                    android:layout_height="160dp"
                    app:cardCornerRadius="12dp">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="8dp"
                        android:text="오늘 운동"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="64dp"
                                android:layout_height="40dp"
                                android:layout_marginLeft="12dp"
                                android:layout_marginTop="8dp"
                                android:text="활동 시간"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/runTime"
                                android:layout_width="48dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginLeft="52dp"
                                android:text="63분"
                                android:textSize="20sp"
                                android:textColor="#FF6666"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:paddingRight="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="92dp"
                                android:layout_height="40dp"
                                android:layout_marginLeft="12dp"
                                android:text="운동 총 볼륨"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/totalV"
                                android:layout_width="60dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="20dp"
                                android:text="20.5k"
                                android:textSize="20sp"
                                android:textColor="#FF6666"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 걸음 수 -->
                <androidx.cardview.widget.CardView
                    android:layout_marginRight="4dp"
                    android:layout_marginLeft="20dp"
                    android:layout_width="0dp"
                    android:elevation="2dp"
                    android:layout_weight="0.6"
                    android:layout_height="160dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="64dp"
                            android:layout_height="30dp"
                            android:text="걸음 수"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/stepCountText"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:text="4,631"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_marginLeft="40dp"
                            android:textColor="#FF6666"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="64dp"
                            android:layout_height="30dp"
                            android:layout_marginTop="8dp"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:text="이동 거리" />

                        <TextView
                            android:id="@+id/distanceText"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:layout_marginLeft="40dp"
                            android:text="1.61KM"
                            android:textSize="20sp"
                            android:textColor="#FF6666"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>


            <LinearLayout
                android:layout_marginHorizontal="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:elevation="2dp"
                android:background="@drawable/rounded_container">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="부위별 통계"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 그래프 영역은 LineChart 등 라이브러리 활용 -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/navigationBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#F9F9F9"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 홈 -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home_selected" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 운동 -->
        <LinearLayout
            android:id="@+id/nav_workout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_workout"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_exercise"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_workout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="운동"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 식단 -->
        <LinearLayout
            android:id="@+id/nav_meal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_meal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_diet"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_meal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="식단"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 친구 -->
        <LinearLayout
            android:id="@+id/nav_friends"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_friends"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_friends"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="친구"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 통계 -->
        <LinearLayout
            android:id="@+id/nav_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_stats"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_stats"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="통계"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
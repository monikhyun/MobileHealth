<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="20dp"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:background="#FEF7FF"
        android:paddingVertical="8dp"
        android:paddingLeft="26dp"
        android:paddingRight="4dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="28dp"
        android:orientation="horizontal">
        <Spinner
            android:id="@+id/topDropdownSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:layout_marginEnd="11dp"
            android:backgroundTint="@android:color/black"
            android:dropDownHorizontalOffset="0dp"
            android:dropDownVerticalOffset="4dp"
            android:gravity="center"
            android:spinnerMode="dropdown" />


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">
        </LinearLayout>
        <ImageView
            android:id="@+id/btn_profile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_alarm"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_alarm"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btn_setting"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_setting"/>
    </LinearLayout>


    <!-- 스크롤 가능한 본문 -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/navigationBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 오늘 식단 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="오늘 식단"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_container"/>

            <!-- 파이차트와 요약 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_container"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/nutritionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="영양소 비율"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintRight_toLeftOf="@+id/labelConst"
                    app:layout_constraintLeft_toLeftOf="parent"/>

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/meal_chart_view"
                    android:layout_width="250dp"
                    android:layout_height="300dp"
                    android:layout_marginRight="4dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="130dp"
                    android:layout_height="match_parent"
                    android:id="@+id/labelConst"
                    android:background="@drawable/rounded_container"
                    android:elevation="4dp"
                    app:layout_constraintLeft_toRightOf="@+id/meal_chart_view"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/labelCarb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="탄수화물"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/valueCarb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFA7A7"
                        android:text=""
                        android:textSize="20sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBaseline_toBaselineOf="@id/labelCarb"/>

                    <TextView
                        android:id="@+id/labelProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="단백질"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/labelCarb"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/valueProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B2EBF4"
                        android:text=""
                        android:textSize="20sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBaseline_toBaselineOf="@id/labelProtein"/>

                    <TextView
                        android:id="@+id/labelFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지방"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/labelProtein"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/valueFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FAED7D"
                        android:text=""
                        android:textSize="20sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBaseline_toBaselineOf="@id/labelFat"/>

                    <TextView
                        android:id="@+id/labelCal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="칼로리"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/labelFat"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/valueCal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFC19E"
                        android:text=""
                        android:textSize="20sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBaseline_toBaselineOf="@id/labelCal"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 동적 식단 표시 영역 -->
            <LinearLayout
                android:id="@+id/mealContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical" />

            <!-- 플로팅 버튼 포함 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:background="@drawable/button_card_bg"
                android:elevation="4dp"
                android:clipToOutline="false"
                android:outlineProvider="bounds">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/buttonAddMeal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:contentDescription="식단 추가"
                    android:src="@android:drawable/ic_input_add"
                    app:backgroundTint="@android:color/holo_green_light"
                    app:tint="@android:color/white" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 네비게이션 바: 기존 navigationBar 재활용 -->
    <LinearLayout
        android:id="@+id/navigationBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F9F9F9"
        android:paddingVertical="8dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 홈 -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 운동 -->
        <LinearLayout
            android:id="@+id/nav_workout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_workout"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_exercise"
                app:tint="#FF7C8C" />

            <TextView
                android:id="@+id/text_workout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="운동"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 식단 -->
        <LinearLayout
            android:id="@+id/nav_meal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_meal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_diet_selected"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_meal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="식단"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 친구 -->
        <LinearLayout
            android:id="@+id/nav_friends"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_friends"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_friends"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="친구"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- 통계 -->
        <LinearLayout
            android:id="@+id/nav_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/icon_stats"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_stats"
                app:tint="#A0A0A0" />

            <TextView
                android:id="@+id/text_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="통계"
                android:textSize="12sp"
                android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
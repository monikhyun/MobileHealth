<!-- res/drawable/round_button.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#FF0000" /> <!-- 버튼 배경 색 (초록) -->

    <corners android:radius="30dp" /> <!-- 둥근 모서리: 완전한 원처럼 보이게 -->

    <stroke
        android:width="1dp"
        android:color="#ffffff" /> <!-- 테두리 색상 (선택) -->

</shape>